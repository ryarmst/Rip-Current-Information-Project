---
layout: base.njk
---

<article class="content">
  <div class="container">
    <p class="eyebrow">News & Updates</p>
    <h1>{{ title }}</h1>
    <p class="post-meta">{{ date | readableDate }} / By {{ author }}</p>
    {{ content | safe }}
    <p><a class="text-link" href="{{ '/news/' | url }}">Back to News & Updates</a></p>
  </div>
</article>
